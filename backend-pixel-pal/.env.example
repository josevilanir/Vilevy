# =====================================================
# VARIÁVEIS DE AMBIENTE — backend-pixel-pal
# Copie este arquivo para .env e preencha os valores
# =====================================================

# --- PostgreSQL (Neon) ---
# Cole a connection string do seu projeto no painel do Neon
# Painel: https://console.neon.tech → seu projeto → Connection Details
DATABASE_URL=postgresql://usuario:senha@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Cloudflare R2 ---
# Painel Cloudflare → R2 → Manage R2 API tokens → Create token (Object Read & Write)
CLOUDFLARE_ACCOUNT_ID=seu_account_id_aqui

R2_ACCESS_KEY_ID=sua_access_key_id_aqui
R2_SECRET_ACCESS_KEY=sua_secret_access_key_aqui

# Nome exato do bucket que você criou no R2
R2_BUCKET_NAME=nome-do-seu-bucket

# URL pública do bucket (ative em R2 → bucket → Settings → Public Access)
# Pode ser o domínio padrão r2.dev ou um domínio customizado
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# --- Servidor ---
PORT=4000

# URL do frontend em produção (para configurar CORS corretamente)
# Ex: https://seu-app.vercel.app
FRONTEND_URL=https://seu-app.vercel.app
